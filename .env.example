# Core runtime
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_API_KEY=lm-studio
MODEL=local-model
AGENT_NAME=son-goku
SEARXNG_URL=http://searxng:8080

# Discord
DISCORD_TOKEN=replace_with_discord_bot_token
DISCORD_LOG_CHANNEL_ID=optional_channel_id

# Notion
NOTION_API_KEY=replace_with_notion_integration_token
NOTION_PARENT_PAGE_ID=replace_with_shared_parent_page_id

# Google Drive OAuth
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.pickle

# Optional reasoning-bank embedding model
EMBEDDING_MODEL=nomic-embed-text-v1.5
